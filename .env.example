# === 在线模式配置 ===
# 为知笔记账号（邮箱）
WIZ_USER_ID=your_email@example.com
# 为知笔记密码
WIZ_PASSWORD=your_password
# 群组名称（可选，仅导出群组笔记时填写）
WIZ_GROUP_NAME=

# === 本地模式配置 ===
# 为知笔记本地数据目录路径（指向 Data/<用户ID> 层级）
# Windows 示例: D:\path\to\My Knowledge\Data\joehwang
# macOS 示例: /Users/xxx/Library/Application Support/WizNote/Data/joehwang
WIZ_LOCAL_PATH=
